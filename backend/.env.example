# Flask Backend Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────
# Flask
# ──────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ──────────────────────────────────────────
# PostgreSQL Database
# ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/auth_db

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars

# ──────────────────────────────────────────
# Gmail SMTP (for OTP emails)
# 1. Enable 2-Step Verification on your Gmail
# 2. Go to Google Account → Security → App Passwords
# 3. Generate an App Password for "Mail"
# ──────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=noreply@schoolerp.com

# ──────────────────────────────────────────
# Google OAuth
# 1. Go to console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web Application)
# 4. Add http://localhost:5173 to Authorized Origins
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ──────────────────────────────────────────
# CORS
# ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────
# Frontend URL
# ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────
# Redis (Optional - for rate limiting storage)
# If not provided, uses in-memory storage
# ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
